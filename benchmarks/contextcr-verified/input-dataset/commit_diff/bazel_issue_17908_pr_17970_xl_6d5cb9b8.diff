+  @Test
+  public void testGenerateFixupMessage() throws EvalException {
+    Location location = Location.fromFileLineColumn("<root>/MODULE.bazel", 2, 1);
+    var rootUsage = ModuleExtensionUsage.builder()
+        .setExtensionBzlFile("//:extensions.bzl")
+        .setExtensionName("ext")
+        .setLocation(location)
+        .setImports(ImmutableBiMap.of("indirect_dep", "indirect_dep", "indirect_dev_dep",
+            "indirect_dev_dep", "invalid_dep", "invalid_dep", "invalid_dev_dep", "invalid_dev_dep"))
+        .setDevImports(ImmutableSet.of("indirect_dev_dep", "invalid_dev_dep"))
+        .build();
+    var allRepos = ImmutableSet.of("direct_dep", "direct_dev_dep", "indirect_dep",
+        "indirect_dev_dep");
+    var moduleExtensionMetadata = ModuleExtensionMetadata.create(ImmutableList.of("direct_dep"),
+        ImmutableList.of("direct_dev_dep"));
+    var fixupMessage = moduleExtensionMetadata.generateFixupMessage(ImmutableList.of(rootUsage),
+        allRepos);
+
+    assertThat(fixupMessage.isPresent()).isTrue();
+    assertThat(fixupMessage.get().getLocation()).isEqualTo(location);
+    assertThat(fixupMessage.get().getKind()).isEqualTo(EventKind.WARNING);
+    assertThat(fixupMessage.get().getMessage()).isEqualTo(
+        "The module extension ext defined in //:extensions.bzl reported incorrect imports of repositories via use_repo():\n"
+            + "\n"
+            + "Imported, but not created by the extension (will cause the build to fail):\n"
+            + "    invalid_dep, invalid_dev_dep\n"
+            + "\n"
+            + "Not imported, but declared as direct dependencies (may cause the build to fail):\n"
+            + "    direct_dep, direct_dev_dep\n"
+            + "\n"
+            + "Imported, but not declared as direct dependencies:\n"
+            + "    indirect_dep, indirect_dev_dep\n"
+            + "\n"
+            + "\033[35m\033[1m ** You can use the following buildozer command(s) to fix these issues:\033[0m\n"
+            + "\n"
+            + "buildozer 'use_repo_add //:extensions.bzl ext direct_dep' //MODULE.bazel:all\n"
+            + "buildozer 'use_repo_remove //:extensions.bzl ext indirect_dep invalid_dep' //MODULE.bazel:all\n"
+            + "buildozer 'use_repo_add dev //:extensions.bzl ext direct_dev_dep' //MODULE.bazel:all\n"
+            + "buildozer 'use_repo_remove dev //:extensions.bzl ext indirect_dev_dep invalid_dev_dep' //MODULE.bazel:all");
+  }
