+    /* 9 bytes of skipped non-base64 input + newline */
+    t.prefix = "#foo\n#bar";
+
+    /* 9 bytes on 2nd and subsequent lines */
+    t.encoded = "A\nAAA\nAAAA\n";
+    t.suffix = "";
+
+    /* Expected decode length */
+    t.bytes = 6;
+    t.trunc = 0;    /* ignored */
+
+    return generic_case(&t, 0);
+}
