+	s.server.CreateObject(fakestorage.Object{
+		ObjectAttrs: fakestorage.ObjectAttrs{
+			BucketName: "test-bucket",
+			Name:       "generated_columns.csv",
+		},
+		Content: []byte("1\t2\n2\t3"),
+	})
+
