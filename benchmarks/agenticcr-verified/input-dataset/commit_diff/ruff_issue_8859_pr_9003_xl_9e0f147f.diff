+    """
+    Do cool stuff.
+
+    ::
+
+        cool_stuff( 1 )
+
+    Done.
+    """
+    pass
+
+
+def rst_directive_simple():
+    """
+    .. code-block:: python
+
+        cool_stuff( 1 )
+
+    Done.
+    """
+    pass
+
+
