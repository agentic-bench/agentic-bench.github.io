+fn is_rst_option(line: &str) -> bool {
+    let line = line.trim_start();
+    if !line.starts_with(':') {
+        return false;
+    }
+    line.chars()
+        .take_while(|ch| !ch.is_whitespace())
+        .any(|ch| ch == ':')
+}
