+func logImageCreateEvent(es *daemonevents.Events, imageID string, tags []reference.Named) {
+	es.Log(events.ActionCreate, events.ImageEventType, events.Actor{
+		ID: imageID,
+		Attributes: map[string]string{
+			"name": imageID,
+		},
+	})
+
+	for _, tag := range tags {
+		es.Log(events.ActionTag, events.ImageEventType, events.Actor{
+			ID: imageID,
+			Attributes: map[string]string{
+				"name": reference.FamiliarString(tag),
+			},
+		})
+	}
+}
