+func TestBuildEmitsImageCreateEvent(t *testing.T) {
+	ctx := setupTest(t)
+
+	dockerfile := "FROM busybox\nRUN date > /date"
+	source := fakecontext.New(t, "", fakecontext.WithDockerfile(dockerfile))
+	defer source.Close()
+
+	apiClient := testEnv.APIClient()
+
+	for _, builderVersion := range []types.BuilderVersion{types.BuilderV1, types.BuilderBuildKit} {
+		builderVersion := builderVersion
+		t.Run("v"+string(builderVersion), func(t *testing.T) {
+			if testEnv.UsingSnapshotter() && builderVersion == types.BuilderBuildKit {
+				t.Skip("FIXME: Passing a context via a tarball is not supported with the containerd. See: https://github.com/moby/moby/issues/47717")
+			}
+
+			ctx, cancel := context.WithCancel(ctx)
+			defer cancel()
+
+			eventsChan, _ := apiClient.Events(ctx, events.ListOptions{})
+
+			resp, err := apiClient.ImageBuild(ctx, source.AsTarReader(t), types.ImageBuildOptions{
+				Version: builderVersion,
+				NoCache: true,
+			})
+			assert.NilError(t, err)
+
+			defer resp.Body.Close()
+
+			out := bytes.NewBuffer(nil)
+			_, err = io.Copy(out, resp.Body)
+			assert.NilError(t, err)
+
+			t.Log(out.String())
+
+			hasEvent := false
+			finished := false
+			for !finished && !hasEvent {
+				select {
+				case evt, ok := <-eventsChan:
+					if !ok {
+						break
+					}
+					t.Log("Got event type:", evt.Type, "action:", evt.Action)
+
+					if evt.Type == events.ImageEventType && evt.Action == events.ActionCreate {
+						hasEvent = true
+					}
+				case <-time.After(time.Millisecond * 3500):
+					finished = true
+				}
+			}
+
+			assert.Check(t, hasEvent, "expected image create event")
+		})
+	}
+}
