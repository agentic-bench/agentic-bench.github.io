+//     FencedCodeBlockParser, 700
+//     BlockquoteParser, 800
+//     HTMLBlockParser, 900
+//     ParagraphParser, 1000
+func DefaultBlockParsers() []util.PrioritizedValue {
+	return []util.PrioritizedValue{
