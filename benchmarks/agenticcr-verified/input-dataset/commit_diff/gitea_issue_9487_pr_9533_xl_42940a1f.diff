+	if n < len(r.peekedLine) && r.pos.Padding == 0 {
+		r.pos.Start += n
+		r.peekedLine = nil
+		return
+	}
+	r.peekedLine = nil
+	l := r.sourceLength
+	for ; n > 0 && r.pos.Start < l; n-- {
+		if r.pos.Padding != 0 {
+			r.pos.Padding--
+			continue
+		}
