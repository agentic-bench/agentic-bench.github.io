-            }
-
-            serde_json::to_writer(&mut dst_file, &document_buffer)?;
-            dst_file.write_all(b"\n")?;
-            document_buffer.clear();
-        }
-
-        dst_file.persist(dst)?;
-
-        Ok(())
-    }
