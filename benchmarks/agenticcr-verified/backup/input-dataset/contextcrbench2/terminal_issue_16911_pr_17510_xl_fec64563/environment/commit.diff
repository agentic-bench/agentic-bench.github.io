-        {
-            invalidRect |= runs[i];
-        }
-
-        // verify the rect matches the invalid one.
-        VERIFY_ARE_EQUAL(invalid, invalidRect);
-
-        // We would expect a CUP here, but we're already at the bottom from the last call.
