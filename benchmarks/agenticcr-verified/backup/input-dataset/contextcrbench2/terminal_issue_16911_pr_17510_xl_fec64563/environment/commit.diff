-        VERIFY_SUCCEEDED(renderer.PaintFrame());
-    }
-
-    for (auto i = 0; i < si.GetViewport().Height(); i++)
-    {
-        hostSm.ProcessString(L"\n");
-        if (paintEachNewline == PaintEveryNewline)
-        {
-            VERIFY_SUCCEEDED(renderer.PaintFrame());
-        }
-    }
-    if (paintEachNewline == PaintAfterAllNewlines)
