-    {
-        RETURN_IF_FAILED(_SetReverseVideo(textAttributes.IsReverseVideo()));
-        _lastTextAttributes.SetReverseVideo(textAttributes.IsReverseVideo());
-    }
-    if (textAttributes.IsUnderlined() != _lastTextAttributes.IsUnderlined())
