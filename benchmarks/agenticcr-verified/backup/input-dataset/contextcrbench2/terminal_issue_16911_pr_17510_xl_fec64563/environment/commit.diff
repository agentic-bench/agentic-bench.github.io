-    Log::Comment(NoThrowString().Format(
-        L"Multiple scrolls are coalesced"));
-
-    scrollDelta = { 0, 1 };
-    VERIFY_SUCCEEDED(engine->InvalidateScroll(&scrollDelta));
-    scrollDelta = { 0, 2 };
-    VERIFY_SUCCEEDED(engine->InvalidateScroll(&scrollDelta));
-    TestPaint(*engine, [&]() {
