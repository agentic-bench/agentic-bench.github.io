-
-	dynamic_bitset<Block, Allocator> reverse_bitset;
-	_CharT val;
-	is.get(val);
-	while(is.good())
-	{
-		if(val == one)
-		{
-			reverse_bitset.push_back(true);
-		}
-		else if(val == zero)
-		{
-			reverse_bitset.push_back(false);
-		}
-		else
-		{
-			is.unget();
-			break;
-		}
