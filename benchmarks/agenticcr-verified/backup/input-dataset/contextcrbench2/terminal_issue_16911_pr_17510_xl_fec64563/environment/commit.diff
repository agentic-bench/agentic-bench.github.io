-    }
-    std::wstring completeCursorAtPromptLine;
-    {
-        std::wstringstream wss;
-        // For 20 tall and 100 wide buffer
-        // ESC[19;1H
-        // Put cursor on line 19 (1 before last) and the left most column 1.
